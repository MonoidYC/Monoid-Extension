{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2022",
		"lib": [
			"ES2022",
			"DOM"
		],
		"sourceMap": true,
		"rootDir": ".",
		"strict": true,
		"paths": {
			"@monoid/analyzer-core": ["./packages/analyzer-core/src/index.ts"],
			"@monoid/analyzer-core/*": ["./packages/analyzer-core/src/*"]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "packages/**/node_modules", "packages/**/dist"]
}
